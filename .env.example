# Modelo de variáveis de ambiente. Copie para .env e preencha (o .env é gitignored).

# Chave secreta da aplicação Flask (OBRIGATÓRIA — sem fallback inseguro).
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# BigQuery — ambiente novo (paralelo ao legado).
BIGQUERY_PROJECT_ID=iptc-banco-de-dados
BIGQUERY_DATASET=premio_esg_setcepar_2026
BIGQUERY_TABLE_USUARIOS=usuarios
BIGQUERY_TABLE_PROJETOS=projetos
BIGQUERY_TABLE_AVALIACOES=avaliacoes

# Credenciais da conta de serviço dedicada (FORA do repositório).
# No Cloud Run, prefira anexar a SA ao serviço em vez de usar a chave JSON.
GOOGLE_APPLICATION_CREDENTIALS=./premio-esg-setcepar-site-key.json
